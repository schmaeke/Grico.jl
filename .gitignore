# macOS / editor noise
.DS_Store
*.swp
*~

# Local Julia environments stay machine-specific.
Manifest.toml

# Benchmark scripts currently emit reports and raw data into benchmark/.
/benchmark/*.md
/benchmark/*.toml
!/benchmark/Project.toml
/benchmark/*.csv
/benchmark/*.pdf
/benchmark/*.png
/benchmark/*.svg
/benchmark/*.txt

# Generated output directories.
/benchmark/output/
/examples/output/
/examples/*/output/

# Local scratch directories.
/old/
/tmp/
